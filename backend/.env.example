# ── Server Configuration ──
PORT=8080
HOST=0.0.0.0
DEBUG=True

# ── Google Generative AI (AI Studio) API Key ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud — Application Default Credentials ──
# In Cloud Run, this is set AUTOMATICALLY by the platform. Do NOT set it manually.
# Locally, point to a service account JSON file that has access to Firebase + Drive.
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ── Firebase Admin SDK ──
# Optional: Explicit path to a Firebase-specific service account JSON.
# If not set, falls back to GOOGLE_APPLICATION_CREDENTIALS → ADC.
# FIREBASE_CREDENTIALS_PATH=path/to/firebase-service-account.json

# Optional: Firebase project ID. Required when using ADC without a JSON key file.
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Google Drive API ──
# Optional: Explicit path to a Drive-specific service account JSON.
# If not set, falls back to GOOGLE_APPLICATION_CREDENTIALS → ADC.
# GOOGLE_DRIVE_CREDENTIALS_PATH=path/to/google-drive-credentials.json

# Root folder IDs in Google Drive
GOOGLE_DRIVE_INBOUND_FOLDER_ID=your_inbound_folder_id_here
GOOGLE_DRIVE_CLIENTS_FOLDER_ID=your_clients_root_folder_id_here

# ── Webhook Trigger URLs ──
CONTENT_BRAIN_WEBHOOK_URL=http://localhost:8080/api/v1/content-brain/process
PUBLISHER_WEBHOOK_URL=http://localhost:8080/api/v1/publisher/trigger
