# Server Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Google Generative AI (AI Studio) API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK Configuration
# Path to the service account JSON key file
FIREBASE_CREDENTIALS_PATH=path/to/firebase-service-account.json

# Google Drive API Configuration
# Path to the service account JSON key file or credentials JSON
GOOGLE_DRIVE_CREDENTIALS_PATH=path/to/google-drive-credentials.json
# Root folders
GOOGLE_DRIVE_INBOUND_FOLDER_ID=your_inbound_folder_id_here
GOOGLE_DRIVE_CLIENTS_FOLDER_ID=your_clients_root_folder_id_here

# Webhook Trigger URLs (if communicating with other external systems)
CONTENT_BRAIN_WEBHOOK_URL=http://localhost:8000/api/v1/content-brain/process
PUBLISHER_WEBHOOK_URL=http://localhost:8000/api/v1/publisher/trigger
